{
  "name": "employee-portal",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "tsc --project tsconfig.json",
    "build:css": "npx tailwindcss -i ./frontend/src/tailwind.css -o ./frontend/dist/tailwind.css",
    "build:frontend": "node scripts/build-frontend.js && npm run build:css",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node src/index.ts",
    "typecheck": "tsc --noEmit && tsc --project frontend/tsconfig.json --noEmit",
    "clean": "rimraf dist frontend/dist",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.1.0",
    "mongoose": "^9.2.1",
    "nodemailer": "^8.0.1",
    "twilio": "^5.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.19.0",
    "fs-extra": "^11.3.3",
    "nodemon": "^3.1.11",
    "postcss": "^8.5.8",
    "rimraf": "^5.0.5",
    "tailwindcss": "^3.4.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "description": ""
}